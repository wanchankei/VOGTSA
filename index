<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VOGTSA × Chamán — Estructura del sitio (bosquejo)</title>
<meta name="description" content="Primer bosquejo de la estructura del sitio de VOGTSA, bajado de la reunión de briefing. Documento de trabajo, no versión definitiva.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js"></script>
<style>
  :root{
    --bg:#ffffff; --bg2:#f5f6f2; --bg3:#eceee6;
    --tint:#f0f6ec; --green:#056B32;
    --ink:#0b0d09; --muted:#5a6153; --dim:#8c9384;
    --lime:#73BE1C; --lime-lt:#a5de5f; --deep:#056B32; --deep-soft:#e2f0e7;
    --amber:#9a6b00; --amber-soft:#fdf4e3;
    --line:rgba(0,0,0,.12); --line-strong:rgba(0,0,0,.24);
    --ease-out:cubic-bezier(0.16,1,0.3,1);
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;background:var(--bg);}
  body{ color:var(--ink); font-family:'Inter',sans-serif; -webkit-font-smoothing:antialiased; overflow-x:hidden; }
  ::selection{ background:var(--lime); color:#0a0c0a; }
  a{ color:inherit; }

  /* ---------- Chrome fijo ---------- */
  nav.topnav{
    position:fixed; top:0; left:0; right:0; z-index:996;
    display:flex; align-items:center; justify-content:space-between; gap:16px;
    padding:14px 5vw; background:rgba(255,255,255,.92); backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  .topnav .brand{ font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:15px; letter-spacing:-.01em; }
  .topnav .brand span{ color:var(--deep); }
  .topnav .right{ display:flex; align-items:center; gap:18px; }
  .topnav .meta{ font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:.12em; color:var(--muted); text-transform:uppercase; }
  @media (max-width:620px){ .topnav .meta{ display:none; } }

  .burger{
    width:38px; height:32px; border:1px solid var(--line-strong); border-radius:3px; background:#fff;
    display:flex; flex-direction:column; justify-content:center; align-items:center; gap:4px;
    cursor:pointer; padding:0; transition:border-color .2s;
  }
  .burger:hover{ border-color:var(--ink); }
  .burger span{ display:block; width:16px; height:1.5px; background:var(--ink); transition:transform .3s var(--ease-out), opacity .2s; }
  body.menu-open .burger span:nth-child(1){ transform:translateY(5.5px) rotate(45deg); }
  body.menu-open .burger span:nth-child(2){ opacity:0; }
  body.menu-open .burger span:nth-child(3){ transform:translateY(-5.5px) rotate(-45deg); }

  .menu{
    position:fixed; top:0; right:0; bottom:0; width:min(360px,88vw); background:#fff; z-index:995;
    border-left:1px solid var(--line); padding:82px 26px 30px; overflow-y:auto;
    transform:translateX(101%); transition:transform .42s var(--ease-out);
    box-shadow:-20px 0 60px rgba(0,0,0,.07);
  }
  body.menu-open .menu{ transform:translateX(0); }
  .menu h4{ font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:.14em; text-transform:uppercase; color:var(--dim); margin:0 0 14px; font-weight:500; }
  .menu a{
    display:flex; gap:12px; align-items:baseline; text-decoration:none; padding:11px 0;
    border-bottom:1px solid rgba(0,0,0,.06); font-size:14.5px; color:var(--ink); transition:color .2s, padding-left .2s;
  }
  .menu a:hover{ color:var(--deep); padding-left:5px; }
  .menu a i{ font-style:normal; font-family:'IBM Plex Mono',monospace; font-size:10.5px; color:var(--dim); flex:none; min-width:18px; }
  .menu-back{ position:fixed; inset:0; background:rgba(11,13,9,.32); z-index:994; opacity:0; pointer-events:none; transition:opacity .35s; }
  body.menu-open .menu-back{ opacity:1; pointer-events:auto; }

  /* Volver al inicio: anillo de progreso de lectura + flecha. Reemplaza al rail lateral:
     dos indicadores de progreso a la vez es ruido. */
  .totop{
    position:fixed; right:26px; bottom:26px; z-index:993;
    width:54px; height:54px; border-radius:50%; border:0; padding:0;
    background:#fff; color:var(--ink); cursor:pointer;
    display:grid; place-items:center;
    opacity:0; pointer-events:none; transform:translateY(12px) scale(.9);
    transition:opacity .3s, transform .4s var(--ease-out), background .25s, color .25s;
    box-shadow:0 4px 26px rgba(0,0,0,.14);
  }
  .totop.on{ opacity:1; pointer-events:auto; transform:translateY(0) scale(1); }
  .totop:hover{ background:var(--deep); color:#fff; }
  .totop > svg{ grid-area:1/1; }
  .totop-ring{ width:54px; height:54px; transform:rotate(-90deg); fill:none; }
  .totop-ring .bg{ stroke:rgba(0,0,0,.09); stroke-width:1.5; }
  .totop:hover .totop-ring .bg{ stroke:rgba(255,255,255,.25); }
  .totop-ring .fill{ stroke:var(--lime); stroke-width:1.5; stroke-linecap:round; }
  .totop-ico{ width:19px; height:19px; fill:none; stroke:currentColor; stroke-width:2.1; stroke-linecap:round; stroke-linejoin:round; }

  /* ---------- Layout ---------- */
  /* Antes: min-height:100vh + justify-content:center en TODAS las secciones.
     Eso fuerza a cada sección a ocupar la pantalla entera, y cuando el contenido es poco
     (la portada, por ejemplo) el texto queda flotando en el medio de un enorme vacío arriba
     y abajo. Ahora cada sección mide lo que su contenido necesita, con el padding como único
     aire fijo. Las secciones con mucho contenido no cambian en nada; se nota solo en las cortas. */
  section{
    position:relative; padding:116px 5vw 84px;
    border-bottom:1px solid var(--line);
  }
  section.tint{ background:var(--tint); border-bottom-color:rgba(0,0,0,.07); }
  section.green{ background:var(--green); border-bottom:0; color:#fff; }
  @media (max-width:760px){ section{ padding:104px 6vw 68px; } }

  .wrap{ width:100%; max-width:1380px; margin:0 auto; }

  /* Encabezado de sección en dos columnas: usa el ancho con columnas, no estirando renglones.
     align-items:start — con 'end' el título se hundía cuando la columna derecha tenía más texto
     y dejaba un hueco enorme arriba. El .58rem alinea ópticamente el primer renglón con el título. */
  .split{ display:grid; grid-template-columns:minmax(0,1.05fr) minmax(0,.95fr); gap:22px 72px; align-items:start; margin-bottom:46px; }
  .split h1, .split h2{ margin-bottom:0; }
  .split > div{ padding-top:.58rem; }
  .split > div > p:last-child{ margin-bottom:0; }
  @media (max-width:900px){
    .split{ grid-template-columns:1fr; gap:16px; margin-bottom:32px; }
    .split > div{ padding-top:0; }
  }

  /* position:sticky en las dos columnas (no align-items:center) — cuando una columna es una
     lista larga (wf) y la otra son notas cortas, centrar dejaba la nota fija a mitad de la lista:
     se veía bien en una captura de la sección entera, pero al leer con scroll normal la nota
     quedaba fuera de pantalla la mayor parte del tiempo. Con sticky, la columna corta te acompaña
     mientras bajás por la lista larga y se despega recién cuando la lista termina. En columnas
     parejas (mismo alto) esto no cambia nada, porque nunca llegan a despegarse. */
  .cols{ display:grid; grid-template-columns:minmax(0,1.3fr) minmax(0,1fr); gap:52px; align-items:start; }
  .cols > div{ position:sticky; top:96px; }
  @media (max-width:1000px){ .cols{ grid-template-columns:1fr; gap:34px; } .cols > div{ position:static; } }

  .duo{ display:grid; grid-template-columns:minmax(0,1fr) minmax(0,1fr); gap:52px; align-items:start; }
  .duo > div{ position:sticky; top:96px; }
  @media (max-width:1000px){ .duo{ grid-template-columns:1fr; gap:34px; } .duo > div{ position:static; } }

  .notes2{ display:grid; grid-template-columns:minmax(0,1fr) minmax(0,1fr); gap:22px; margin-top:30px; align-items:start; }
  @media (max-width:900px){ .notes2{ grid-template-columns:1fr; } }

  .kicker{ font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:.18em; color:var(--muted); text-transform:uppercase; margin-bottom:22px; display:flex; align-items:center; gap:12px; }
  .kicker::before{ content:""; width:28px; height:2px; background:var(--lime); flex:none; }
  .kicker b{ color:var(--deep); font-weight:600; }

  h1{ font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:clamp(34px,4.6vw,64px); line-height:1.05; letter-spacing:-.03em; margin:0 0 26px; }
  h2{ font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:clamp(28px,3.4vw,46px); line-height:1.09; letter-spacing:-.025em; margin:0 0 22px; }
  h1 em, h2 em{ font-style:normal; color:var(--deep); }
  p{ font-size:clamp(15px,1.05vw,16.5px); line-height:1.68; color:var(--muted); margin:0 0 16px; max-width:64ch; }
  p strong{ color:var(--ink); font-weight:600; }
  .lead{ font-size:clamp(16px,1.2vw,18.5px); color:var(--ink); max-width:60ch; }

  section.green .kicker{ color:rgba(255,255,255,.72); }
  section.green .kicker b{ color:#fff; }
  section.green .kicker::before{ background:var(--lime-lt); }
  section.green h1, section.green h2{ color:#fff; }
  section.green h1 em, section.green h2 em{ color:var(--lime-lt); }
  section.green p{ color:rgba(255,255,255,.84); }
  section.green p strong{ color:#fff; }
  section.green .lead{ color:#fff; }
  section.green .card{ background:rgba(255,255,255,.08); border-color:rgba(255,255,255,.2); border-top-color:var(--lime); }
  section.green .card h3{ color:#fff; }
  section.green .card p{ color:rgba(255,255,255,.82); }
  section.green .note{ background:rgba(255,255,255,.1); border-left-color:var(--lime); }
  section.green .note p{ color:rgba(255,255,255,.9); }
  section.green .btn{ background:transparent; border-color:rgba(255,255,255,.45); color:#fff; }
  section.green .btn:hover{ border-color:#fff; background:rgba(255,255,255,.08); }
  section.green .btn.primary{ background:var(--lime); border-color:var(--lime); color:#08300f; }
  section.green .btn.primary:hover{ background:#fff; color:var(--green); }
  section.green .fig{ background:rgba(255,255,255,.08); border-color:rgba(255,255,255,.2); }
  section.green .fig .l{ color:rgba(255,255,255,.7); }
  section.green .foot-meta{ color:rgba(255,255,255,.55); }

  .note{ border-left:3px solid var(--lime); background:var(--bg2); padding:18px 22px; margin:26px 0 0; max-width:74ch; }
  .note p{ margin:0; max-width:none; }
  .notes2 .note, .cols .note, .duo .note{ max-width:none; }
  /* Una nota suelta justo debajo de un bloque .duo hereda el límite de 74ch pensado para
     texto en una sola columna, y queda angosta y apretada contra las dos columnas de arriba.
     Ahí sí tiene que ocupar el ancho completo de las dos columnas. */
  .duo + .note{ max-width:none; }
  section.tint .note{ background:#fff; }
  .note.amber{ border-left-color:var(--amber); background:var(--amber-soft); }
  .note.amber p{ color:#5c4200; }

  /* ---------- Wireframe ---------- */
  .wf{ border:1px solid var(--line-strong); border-radius:3px; background:#fff; overflow:hidden; width:100%; }
  .wf-head{ background:var(--ink); color:#fff; padding:9px 14px; font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:.1em; text-transform:uppercase; display:flex; justify-content:space-between; align-items:center; gap:10px; }
  .wf-head span{ color:var(--lime); }
  .wf-body{ padding:10px; display:flex; flex-direction:column; gap:7px; background:var(--bg2); }
  .blk{ background:#fff; border:1px solid var(--line); border-radius:2px; padding:11px 13px; display:flex; gap:11px; align-items:flex-start; }
  .blk .n{ font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--dim); flex:none; padding-top:2px; min-width:16px; }
  .blk .t{ font-size:14px; font-weight:600; color:var(--ink); line-height:1.35; }
  .blk .d{ font-size:12.5px; color:var(--muted); line-height:1.45; margin-top:3px; }
  .blk.key{ border-color:var(--deep); background:var(--deep-soft); }
  .blk.key .t{ color:var(--deep); }
  .blk.foot{ background:var(--bg3); }
  .blk.idea{ border-style:dashed; border-color:var(--amber); background:var(--amber-soft); }
  .blk.idea .t{ color:#7a5400; }
  .blk.idea .d{ color:#6b4c05; }
  .pill{ display:inline-block; font-family:'IBM Plex Mono',monospace; font-size:9px; letter-spacing:.08em; text-transform:uppercase; background:var(--amber); color:#fff; padding:2px 6px; border-radius:2px; margin-left:7px; vertical-align:2px; }
  .wf-cap{ font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); margin-bottom:10px; }
  section.green .wf-cap{ color:rgba(255,255,255,.65); }

  /* ---------- Mapa ---------- */
  .map{ background:#fff; border:1px solid var(--line); border-radius:3px; padding:18px 22px; }
  .map-row{ display:flex; align-items:center; gap:12px; padding:9px 0; border-bottom:1px solid rgba(0,0,0,.05); }
  .map-row:last-child{ border-bottom:0; }
  .map-row .pg{ flex:none; width:15px; height:19px; border:1.5px solid var(--dim); border-radius:2px; background:#fff; position:relative; }
  .map-row .pg::after{ content:""; position:absolute; left:3px; right:3px; top:4px; height:1.5px; background:var(--dim); box-shadow:0 4px 0 var(--dim), 0 8px 0 var(--dim); }
  .map-row .nm{ font-size:15px; color:var(--ink); font-weight:500; }
  .map-row .rol{ margin-left:auto; font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:.06em; color:var(--dim); text-transform:uppercase; text-align:right; flex:none; }
  .map-row.main{ padding:12px 0; }
  .map-row.main .nm{ font-size:19px; font-weight:700; font-family:'Space Grotesk',sans-serif; }
  .map-row.main .pg{ width:19px; height:24px; border-color:var(--deep); border-width:2px; }
  .map-row.main .pg::after{ background:var(--deep); box-shadow:0 4px 0 var(--deep), 0 8px 0 var(--deep); }
  .map-row.main .rol{ color:var(--deep); font-weight:600; }
  .map-row.hub{ background:var(--deep-soft); margin:4px -12px; padding:11px 12px; border-radius:3px; border-bottom:0; }
  .map-row.hub .nm{ font-weight:700; color:var(--deep); }
  .map-row.hub .pg{ border-color:var(--deep); }
  .map-row.hub .pg::after{ background:var(--deep); box-shadow:0 4px 0 var(--deep), 0 8px 0 var(--deep); }
  .map-row.hub .rol{ color:var(--deep); }
  .map-row.child{ padding-left:34px; }
  .map-row.child .nm{ font-size:14px; color:var(--muted); font-weight:400; }
  .map-row.child .pg{ width:12px; height:15px; }
  .map-row.child .pg::after{ top:3px; box-shadow:0 3px 0 var(--dim); }
  .ej{ font-family:'IBM Plex Mono',monospace; font-size:10px; color:var(--amber); background:var(--amber-soft); border:1px solid rgba(154,107,0,.3); padding:1px 6px; border-radius:2px; margin-left:8px; text-transform:none; letter-spacing:0; }
  .map-legend{ margin-top:16px; font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--muted); line-height:1.9; }
  .map-legend i{ font-style:normal; color:var(--deep); font-weight:600; }
  @media (max-width:640px){
    .map-row{ flex-wrap:wrap; }
    .map-row .rol{ margin-left:27px; width:100%; text-align:left; margin-top:3px; }
  }

  /* ---------- Nav mock ---------- */
  .navmock{ border:1px solid var(--line-strong); border-radius:3px; background:#fff; }
  .navmock-bar{ display:flex; align-items:center; gap:6px; flex-wrap:wrap; padding:14px 18px; border-bottom:1px solid var(--line); }
  .navmock-bar .logo{ font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:15px; margin-right:14px; }
  .navmock-bar .item{ font-size:13.5px; color:var(--muted); padding:6px 10px; border-radius:2px; }
  .navmock-bar .item.act{ background:var(--deep-soft); color:var(--deep); font-weight:600; }
  .navmock-bar .spacer{ flex:1; }
  .navmock-bar .lang{ font-family:'IBM Plex Mono',monospace; font-size:11px; border:1px solid var(--line-strong); padding:5px 9px; border-radius:2px; }
  .navmock-bar .cta{ font-size:12.5px; font-weight:600; background:var(--lime); color:#0a0c0a; padding:7px 13px; border-radius:2px; white-space:nowrap; }
  .navmock-drop{ padding:16px 18px 20px; background:var(--bg2); display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:8px 24px; }
  .navmock-drop .dl{ font-size:13px; color:var(--ink); padding:5px 0; border-bottom:1px solid var(--line); }
  .navmock-drop .dh{ grid-column:1/-1; font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:.12em; text-transform:uppercase; color:var(--dim); margin-bottom:2px; }

  /* ---------- Tabla ---------- */
  table.cmp{ border-collapse:collapse; width:100%; background:#fff; }
  table.cmp th, table.cmp td{ text-align:left; padding:15px 18px; border-bottom:1px solid var(--line); font-size:14.5px; vertical-align:top; }
  table.cmp th{ font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); font-weight:500; }
  table.cmp th.pick{ color:var(--deep); }
  table.cmp td.pick{ background:var(--deep-soft); font-weight:500; }
  table.cmp td:first-child{ color:var(--muted); }

  .figs{ display:flex; flex-wrap:wrap; gap:14px; }
  .fig{ border:1px solid var(--line); border-top:3px solid var(--lime); border-radius:2px; padding:16px 22px; background:var(--bg2); min-width:150px; flex:1 1 auto; max-width:230px; }
  .fig .v{ font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:30px; letter-spacing:-.02em; line-height:1; }
  .fig .l{ font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); margin-top:8px; }

  /* 3 columnas fijas, no auto-fit: con 6 tarjetas el auto-fit armaba 5 columnas
     y dejaba la sexta huérfana en una fila sola. Así van 3+3 y 3 justas. */
  .cards{ display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:16px; }
  @media (max-width:1040px){ .cards{ grid-template-columns:repeat(2,minmax(0,1fr)); } }
  @media (max-width:660px){ .cards{ grid-template-columns:1fr; } }
  .card{ border:1px solid var(--line); border-top:3px solid var(--lime); padding:20px 22px; background:var(--bg2); border-radius:2px; }
  section.tint .card{ background:#fff; }
  .card h3{ font-family:'Space Grotesk',sans-serif; font-size:17px; margin:0 0 8px; letter-spacing:-.01em; }
  .card p{ font-size:14px; margin:0; max-width:none; }

  .btn{ display:inline-block; font-family:'IBM Plex Mono',monospace; font-size:12.5px; letter-spacing:.08em; text-transform:uppercase; text-decoration:none; padding:15px 26px; border:1px solid var(--line-strong); border-radius:2px; color:var(--ink); background:#fff; transition:all .25s var(--ease-out); }
  .btn:hover{ border-color:var(--ink); }
  .btn.primary{ border-color:var(--deep); background:var(--deep); color:#fff; }
  .btn.primary:hover{ background:#fff; color:var(--deep); }
  .btns{ display:flex; flex-wrap:wrap; gap:12px; margin-top:32px; }

  /* Bloque de cierre (nota + botones + pie): antes quedaba angosto (74ch) y pegado a la
     izquierda, debajo de un encabezado a dos columnas mucho más ancho. Centrarlo como bloque
     lo convierte en el remate visual de la página en vez de un resto desalineado. */
  .cta{ max-width:640px; margin:44px auto 0; text-align:center; }
  .cta .note{ max-width:none; text-align:left; margin-top:0; }
  .cta .btns{ justify-content:center; }
  .cta .foot-meta{ text-align:center; margin-left:auto; margin-right:auto; }

  .flow{ font-family:'IBM Plex Mono',monospace; font-size:12.5px; color:var(--muted); line-height:2.1; background:#fff; border:1px solid var(--line); padding:16px 20px; border-radius:3px; }
  .flow b{ color:var(--deep); }
  hr.sep{ border:0; border-top:1px solid var(--line); margin:30px 0; }
  .foot-meta{ font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:.1em; color:var(--dim); text-transform:uppercase; }
</style>
</head>
<body>

<nav class="topnav">
  <div class="brand">VOGTSA <span>×</span> CHAMÁN</div>
  <div class="right">
    <div class="meta">Bosquejo de trabajo</div>
    <button class="burger" id="burger" aria-label="Abrir menú" aria-expanded="false"><span></span><span></span><span></span></button>
  </div>
</nav>

<div class="menu-back" id="menuBack"></div>
<nav class="menu" id="menu" aria-label="Índice del documento">
  <h4>Índice</h4>
  <a href="#s0"><i>00</i>Estructura del sitio</a>
