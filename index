<script>
  var lenis = null;
  if (window.Lenis) {
    lenis = new Lenis({ duration:1.1, smoothWheel:true });
    function raf(t){ lenis.raf(t); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
    if (window.ScrollTrigger) lenis.on('scroll', ScrollTrigger.update);
  }
  function goTo(target){
    if (lenis) lenis.scrollTo(target, { offset:0, duration:1.2 });
    else if (typeof target === 'number') window.scrollTo({ top:target, behavior:'smooth' });
    else document.querySelector(target).scrollIntoView({ behavior:'smooth' });
  }

  // Menú
  var burger = document.getElementById('burger');
  var menuBack = document.getElementById('menuBack');
  function closeMenu(){ document.body.classList.remove('menu-open'); burger.setAttribute('aria-expanded','false'); }
  burger.addEventListener('click', function(){
    var open = document.body.classList.toggle('menu-open');
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  menuBack.addEventListener('click', closeMenu);
  document.addEventListener('keydown', function(e){ if (e.key === 'Escape') closeMenu(); });
  document.querySelectorAll('#menu a').forEach(function(a){
    a.addEventListener('click', function(e){
      e.preventDefault();
      closeMenu();
      setTimeout(function(){ goTo(a.getAttribute('href')); }, 120);
    });
  });

  // Volver al inicio + anillo de progreso de lectura
  var totop = document.getElementById('totop');
  var ringFill = document.getElementById('ringFill');
  var CIRC = 2 * Math.PI * 25.5;
  ringFill.style.strokeDasharray = CIRC;
  ringFill.style.strokeDashoffset = CIRC;
  totop.addEventListener('click', function(){ goTo(0); });
  function onScroll(y){
    totop.classList.toggle('on', y > 700);
    var max = document.documentElement.scrollHeight - window.innerHeight;
    var p = max > 0 ? Math.min(1, Math.max(0, y / max)) : 0;
    ringFill.style.strokeDashoffset = CIRC * (1 - p);
  }
  if (lenis) lenis.on('scroll', function(e){ onScroll(e.scroll); });
  else window.addEventListener('scroll', function(){ onScroll(window.scrollY); });

  // Reveals
  if (window.gsap && window.ScrollTrigger) {
    gsap.registerPlugin(ScrollTrigger);
    gsap.utils.toArray('section').forEach(function(sec){
      var bits = sec.querySelectorAll('.kicker, h1, h2, .split > div, .note, .figs, .cards, .map, .map-legend, .navmock, .wf, table.cmp, .btns, .flow, .wf-cap, .foot-meta, section > .wrap > p');
      gsap.set(bits, { opacity:0, y:22 });
      ScrollTrigger.create({
        trigger: sec, start:'top 72%', once:true,
        onEnter:function(){ gsap.to(bits, { opacity:1, y:0, duration:.7, stagger:.04, ease:'power3.out' }); }
      });
    });
  }
</script>
